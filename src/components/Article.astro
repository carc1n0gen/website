---
import { render } from "astro:content";

import Button from "./Button.astro";

const { post, isPreview = false } = Astro.props;

const { Content } = await render(post);
---
<article class="mb-16 last:mb-0">
  <header>
    <a href={post.data.url}>
      <h1 class="text-2xl md:text-4xl font-normal mb-0">{post.data.title}</h1>
    </a>
    <p class="ml-1 mb-4 text-sm text-zinc-500">
      posted on {post.data.date.toLocaleString("default", {
        month: "short",
        day: "numeric",
        year: "numeric",
      })}
    </p>
  </header>
  <section>
    {isPreview ? (
      <>
        <p class="mb-4">{post.data.description}</p>
        <Button as="a" href={post.data.url}>Read more</Button>
      </>
    ) : (
      <Content />
    )}
  </section>
  {!isPreview && (
    <footer class="mt-6">
      <p class="mt-6">
        Updated on {post.data.updated?.toLocaleString("default", {
          month: "short",
          day: "numeric",
          year: "numeric",
        })}
      </p>
    </footer>
  )}
</article>
