---
import { render } from "astro:content";

import Button from "./Button.astro";
import Paragraph from "./Paragraph.astro";
import Anchor from "./Anchor.astro";
import H1 from "./H1.astro";
import H2 from "./H2.astro";
import H3 from "./H3.astro";
import H4 from "./H4.astro";
import H5 from "./H5.astro";
import H6 from "./H6.astro";
import CodeBlock from "./CodeBlock.astro";
import Code from "./Code.astro";
import OrderedList from "./OrderedList.astro";
import UnorderedList from "./UnorderedList.astro";

const components = {
  p: Paragraph,
  a: Anchor,
  h1: H1,
  h2: H2,
  h3: H3,
  h4: H4,
  h5: H5,
  h6: H6,
  ol: OrderedList,
  ul: UnorderedList,
  pre: CodeBlock,
  code: Code,
};

const { post, isPreview = false } = Astro.props;

const { Content } = await render(post);
---

<article class="mb-16 [&:last-of-type]:mb-0">
  <header>
    <a href={post.data.url}>
      <h1 class="text-3xl font-bold md:text-4xl mb-0">{post.data.title}</h1>
    </a>
    <p class="mt-1 mb-4 text-sm text-zinc-500">
      posted on {
        post.data.date.toLocaleString("default", {
          month: "short",
          day: "numeric",
          year: "numeric",
          timeZone: "UTC",
        })
      }
      {
        post.data.tags.map((tag) => (
          <a href={`/blog/tags/${tag}`} class="ml-2 lowercase">
            <span class="before:content-['#']">{tag}</span>
          </a>
        ))
      }
    </p>
  </header>
  <section>
    {
      isPreview ? (
        <>
          <Paragraph>{post.data.description}</Paragraph>
          <Button as="a" href={post.data.url}>
            Read more
          </Button>
        </>
      ) : (
        <Content components={{ ...components }} />
      )
    }
  </section>
  {
    !isPreview && (
      <footer class="mt-6">
        <p class="mt-6">
          Updated on{" "}
          {post.data.updated.toLocaleString("default", {
            month: "short",
            day: "numeric",
            year: "numeric",
            timeZone: "UTC",
          })}
        </p>
        <div id="disqus_thread" />
        <noscript>
          Please enable JavaScript to view the{" "}
          <a href="https://disqus.com/?ref_noscript">
            comments powered by Disqus.
          </a>
        </noscript>
      </footer>
    )
  }
</article>
