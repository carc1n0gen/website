---
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/Button.astro";
import Input from "@/components/Input.astro";
import { FORM_SPREES_ID, RECAPTCHA_SITE_KEY } from "@/constants";
---

<Layout title="Contact me">
  <form action={`https://formspree.io/f/${FORM_SPREES_ID}`} method="POST">
    <h1 class="text-3xl font-bold mb-4">Contact Me</h1>
    <p class="py-4">
      Fill out this form to send me an email, and I will get back to you as soon
      as I can.
    </p>
    <div class="flex flex-col gap-4">
      <div class="flex flex-col md:flex-row gap-4">
        <Input type="text" id="name" name="name" placeholder="name" />
        <Input type="email" id="email" name="email" placeholder="email" />
      </div>
      <div class="flex flex-row gap-4">
        <Input
          as="textarea"
          id="message"
          name="message"
          rows="10"
          placeholder="type a message"
        />
      </div>
      <div class="flex flex-col md:flex-row gap-4 items-center">
        <div class="g-recaptcha flex-shrink" data-sitekey={RECAPTCHA_SITE_KEY}>
        </div>
        <Button type="submit" class="w-full sm:w-auto md:ml-auto">
          Send Message
        </Button>
      </div>
    </div>
  </form>
</Layout>
<script is:inline src="https://www.google.com/recaptcha/api.js" async defer
></script>
<script>
  const form = document.querySelector("form");
  const success = document.querySelector("#success");
  const error = document.querySelector("#error");
  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const formData = new FormData(form);
    const response = await fetch(form.action, {
      method: form.method,
      body: formData,
      headers: {
        Accept: "application/json",
      },
    });

    if (response.ok) {
      const resData = await response.json();
      console.log(resData);
      window.location.href = "/contact/success";
    } else {
      window.location.href = "/contact/error";
    }
  });
</script>
