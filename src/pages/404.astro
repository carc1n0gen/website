---
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/Button.astro";
---

<Layout title="404">
  <h1 class="text-3xl font-bold mb-4">Are you lost?</h1>
  <p class="mb-4">The page you are looking for does not exist.</p>
  <Button as="a" href="/" class="text-blue-500 hover:underline">
    Go back home
  </Button>
</Layout>
